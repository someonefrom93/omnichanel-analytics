# omc-analytics — environment variable examples
# Copy to .env and fill in your values. Never commit .env to version control.

# ---------------------------------------------------------------------------
# Backend selection
# ---------------------------------------------------------------------------
# Secrets backend: memory (default, no AWS) | kms (production, requires AWS)
OMCAE_SECRETS_BACKEND=memory

# Logs backend: memory (default) | sqlite (file-based) | postgres (production)
OMCAE_LOGS_BACKEND=memory

# ---------------------------------------------------------------------------
# Required when OMCAE_SECRETS_BACKEND=kms
# ---------------------------------------------------------------------------
# KMS CMK KeyId or ARN (e.g., arn:aws:kms:us-east-1:123456789:key/mrk-xxxxx
# or alias/my-key)
OMCAE_KMS_KEY_ID=

# AWS region for boto3 S3 and KMS clients (default: us-east-1)
OMCAE_AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# Required when OMCAE_LOGS_BACKEND=postgres
# ---------------------------------------------------------------------------
# PostgreSQL DSN (e.g., postgresql://user:pass@localhost:5432/omc_analytics)
OMCAE_PG_DSN=

# ---------------------------------------------------------------------------
# Standard AWS credentials (used by boto3 S3 and KMS clients)
# Required when OMCAE_SECRETS_BACKEND=kms
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# dbt (Silver transformation)
# ---------------------------------------------------------------------------
# Profile target: dev (local DuckDB) | prod (S3 via httpfs)
OMCAE_DBT_TARGET=dev

# Path to the DuckDB file (local for dev, not used for prod with httpfs)
OMCAE_DUCKDB_PATH=dbt_project/dev.duckdb

# dbt profiles directory (defaults to ~/.dbt on POSIX, %USERPROFILE%\.dbt on Windows)
OMCAE_DBT_PROFILES_DIR=

# Bronze S3 path or local mirror (dev: local mirror path; prod: s3://bucket/prefix)
OMCAE_BRONZE_PATH=s3://ofae-data-lakehouse-bronze-dev/otter

# S3 bucket names
OMCAE_S3_BUCKET_BRONZE=ofae-data-lakehouse-bronze-dev
OMCAE_S3_BUCKET_SILVER=ofae-data-lakehouse-silver-dev

# Optional: DuckDB httpfs init SQL for prod (e.g., SET statements for S3 creds)
OMCAE_DBT_DUCKDB_HTTPFS_INIT_SQL=

# Dev-only: set to 'true' to bypass S3 path and read from pre-created bronze.orders table
# (useful for integration testing with moto S3)
OMCAE_USE_LOCAL_BRONZE=false
