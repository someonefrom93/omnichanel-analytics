# omc-analytics — environment variable examples
# Copy to .env and fill in your values. Never commit .env to version control.

# ---------------------------------------------------------------------------
# Backend selection
# ---------------------------------------------------------------------------
# Secrets backend: memory (default, no AWS) | kms (production, requires AWS)
OMCAE_SECRETS_BACKEND=memory

# Logs backend: memory (default) | sqlite (file-based) | postgres (production)
OMCAE_LOGS_BACKEND=memory

# ---------------------------------------------------------------------------
# Required when OMCAE_SECRETS_BACKEND=kms
# ---------------------------------------------------------------------------
# KMS CMK KeyId or ARN (e.g., arn:aws:kms:us-east-1:123456789:key/mrk-xxxxx
# or alias/my-key)
OMCAE_KMS_KEY_ID=

# AWS region for boto3 S3 and KMS clients (default: us-east-1)
OMCAE_AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# Required when OMCAE_LOGS_BACKEND=postgres
# ---------------------------------------------------------------------------
# PostgreSQL DSN (e.g., postgresql://user:pass@localhost:5432/omc_analytics)
OMCAE_PG_DSN=

# ---------------------------------------------------------------------------
# Standard AWS credentials (used by boto3 S3 and KMS clients)
# Required when OMCAE_SECRETS_BACKEND=kms
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
